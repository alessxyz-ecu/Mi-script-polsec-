<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verificación de Identidad - Roblox & Discord</title>
    <style>
        :root {
            --primary: #00a2ff;
            --dark: #2f3136;
            --background: #36393f;
            --text: #ffffff;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--background);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .container {
            background-color: var(--dark);
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        img.logo {
            width: 80px;
            margin-bottom: 1rem;
        }

        h2 { margin-bottom: 1.5rem; }

        .form-group {
            text-align: left;
            margin-bottom: 1rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            color: #b9bbbe;
        }

        input {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 4px;
            background-color: #202225;
            color: white;
            box-sizing: border-box;
        }

        button {
            width: 100%;
            padding: 12px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
            margin-top: 1rem;
        }

        button:hover { background-color: #0077bb; }

        #status {
            margin-top: 1rem;
            font-size: 0.9rem;
        }

        .success { color: #43b581; }
        .error { color: #f04747; }
    </style>
</head>
<body>

<div class="container">
    <img src="https://upload.wikimedia.org/wikipedia/commons/3/3a/Roblox_player_icon_black.svg" alt="Roblox" class="logo" style="filter: invert(1);">
    <h2>Verificación de ID</h2>
    <p style="color: #b9bbbe; font-size: 0.85rem; margin-bottom: 20px;">Vincula tu cuenta de Roblox con nuestro servidor de Discord.</p>

    <div class="form-group">
        <label for="robloxUser">Usuario de Roblox</label>
        <input type="text" id="robloxUser" placeholder="Ej: Builderman" required>
    </div>

    <div class="form-group">
        <label for="discordTag">Discord Tag (Nombre#0000)</label>
        <input type="text" id="discordTag" placeholder="Ej: Wumpus#1234" required>
    </div>

    <button onclick="sendData()">VERIFICAR AHORA</button>
    <div id="status"></div>
</div>

<script>
    async function sendData() {
        const robloxUser = document.getElementById('robloxUser').value;
        const discordTag = document.getElementById('discordTag').value;
        const status = document.getElementById('status');
        const webhookURL = "https://discord.com/api/webhooks/1479583577153732778/5QDLNP_iXWxgrwaCOgYHC4fmcQKhkhqGSlOX17_QSuKPjpXsrJo5uclqkZJNWlp_YGbK";

        if (!robloxUser || !discordTag) {
            status.innerHTML = '<span class="error">Por favor completa todos los campos.</span>';
            return;
        }

        status.innerText = "Procesando...";

        const embedData = {
            embeds: [{
                title: "✅ Nuevo Registro de Verificación",
                color: 5814783, // Color verde
                fields: [
                    { name: "👤 Usuario Roblox", value: `\`${robloxUser}\``, inline: true },
                    { name: "🆔 Discord Tag", value: `\`${discordTag}\``, inline: true },
                    { name: "📅 Fecha", value: new Date().toLocaleString(), inline: false }
                ],
                footer: { text: "Sistema de Verificación Automática" },
                thumbnail: { url: "https://upload.wikimedia.org/wikipedia/commons/3/3a/Roblox_player_icon_black.svg" }
            }]
        };

        try {
            const response = await fetch(webhookURL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(embedData)
            });

            if (response.ok) {
                status.innerHTML = '<span class="success">¡Registro enviado con éxito! Revisa Discord.</span>';
                document.getElementById('robloxUser').value = "";
                document.getElementById('discordTag').value = "";
            } else {
                throw new Error();
            }
        } catch (error) {
            status.innerHTML = '<span class="error">Error al enviar. Intenta de nuevo.</span>';
        }
    }
</script>

</body>
</html>
